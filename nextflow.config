profiles {
  core {
    params {
      proteomes = "$baseDir/data/core/coreFastas.tar.gz"
      outputDir = "$launchDir/coreOutput"
      outdatedOrganisms = "$baseDir/data/core/outdated.txt"
      diamondSimilarityCache = "$baseDir/data/core/diamondSimilarityCache"
      orthoFinderDiamondOutputFields = "qseqid sseqid pident length mismatch gapopen qstart qend sstart send evalue bitscore"
      buildVersion = "7"
    }
    docker {
      enabled = true
      runOptions='--user root'
    }
    singularity {
      enabled = false
    }
  }
  peripheral {
    params {
      outputDir = "$launchDir/peripheralOutput"
      coreProteomes = "$baseDir/data/core/coreFastas.tar.gz"
      peripheralProteomes = "$baseDir/data/peripherals/peripherals.tar.gz"
      coreGroupsFile = "$baseDir/coreOutput/reformattedGroups.txt"
      coreGroupSimilarities = "$baseDir/coreOutput/groupDiamondResults"
      coreTranslateSequenceFile = "$baseDir/coreOutput/diamondCache/SequenceIDs.txt"
      outdatedOrganisms = "$baseDir/data/peripherals/outdated.txt"
      peripheralDiamondCache = "$baseDir/data/peripherals/cache"
      buildVersion = "7"
      orthoFinderDiamondOutputFields = "qseqid sseqid pident length mismatch gapopen qstart qend sstart send evalue bitscore"
    }
    docker {
      enabled = true
    }
    singularity {
      enabled = false
    }

  }
  residual {
    params {
      outputDir = "$launchDir/residualOutput"
      residualFastaDir = "$launchDir/peripheralOutput/residualFastas.tar.gz"
      orthoFinderDiamondOutputFields = "qseqid sseqid pident length mismatch gapopen qstart qend sstart send evalue bitscore"
    }
    docker {
      enabled = true
    }
    singularity {
      enabled = false
    }
  }
  postResidual {
    params {
      outputDir = "$launchDir/postResidualOutput"
      residualFasta = "$launchDir/residualOutput/residualFasta.fa"
      groupsFile = "$baseDir/residualOutput/Orthogroups.txt"
      speciesMapping = "$baseDir/residualOutput/SpeciesIDs.txt"
      sequenceMapping = "$baseDir/residualOutput/SequenceIDs.txt"
      diamondResultsFile = "$baseDir/residualOutput/blastsFile.txt"      
      buildVersion = "7"
      residualBuildVersion = "1"
    }
    docker {
      enabled = true
    }
    singularity {
      enabled = false
    }
  }
  postProcessing {
    params {
      outputDir = "$launchDir/postProcessingOutput"
      residualFasta = "$launchDir/residualOutput/residualFasta.fa"
      residualBestRepsFasta = "$launchDir/postResidualOutput/bestReps.fasta"
      coreBestRepsFasta = "$launchDir/peripheralOutput/coreBestReps.fasta"
      coreAndPeripheralGroups = "$baseDir/peripheralOutput/GroupsFile.txt"
      coreAndPeripheralProteome = "$baseDir/peripheralOutput/fullProteome.fasta"
      residualGroups = "$baseDir/postResidualOutput/reformattedGroups.txt"
      buildVersion = "7"
      oldGroupsFile = "$baseDir/data/previousGroups/groups_OrthoMCL-CURRENT.txt"
      bestRepDiamondOutputFields = "qseqid sseqid evalue"
      coreGroupFastas = "$launchDir/peripheralOutput/groupFastas"
      residualGroupFastas = "$launchDir/postResidualOutput/residualGroupFastas"
    }
    docker {
      enabled = true
    }
    singularity {
      enabled = false
    }
  }
  updatePeripheral {
    params {
      outputDir                   = "$launchDir/updatePeripheralOutput"
      newPeripheralProteomes      = "$baseDir/data/updatePeripherals.tar.gz"
      coreProteomes               = "$baseDir/data/core/coreFastas.tar.gz"
      coreGroupsFile              = "$baseDir/coreOutput/reformattedGroups.txt"
      existingGroupsFile          = "$baseDir/peripheralOutput/GroupsFile.txt"
      existingBestReps            = "$baseDir/peripheralOutput/coreBestReps.txt"
      existingFullProteome        = "$baseDir/peripheralOutput/fullProteome.fasta"
      coreGroupSimilarities       = "$baseDir/coreOutput/groupDiamondResults"
      peripheralDiamondCache      = "$baseDir/peripheralOutput/newPeripheralDiamondCache"
      coreTranslateSequenceFile   = "$baseDir/coreOutput/diamondCache/SequenceIDs.txt"
      buildVersion                = "7"
      orthoFinderDiamondOutputFields = "qseqid sseqid pident length mismatch gapopen qstart qend sstart send evalue bitscore"
    }
    docker {
      enabled = true
    }
    singularity {
      enabled = false
    }
  }
  updateResidual {
    params {
      outputDir                  = "$launchDir/updateResidualOutput"
      newResidualFastaDir        = "$launchDir/updatePeripheralOutput/residualFastas.tar.gz"
      existingResidualGroupsFile = "$baseDir/postResidualOutput/reformattedGroups.txt"
      buildVersion               = "7"
      newResidualBuildVersion    = "2"
      orthoFinderDiamondOutputFields = "qseqid sseqid pident length mismatch gapopen qstart qend sstart send evalue bitscore"
    }
    docker {
      enabled = true
    }
    singularity {
      enabled = false
    }
  }
  postUpdate {
    params {
      outputDir                    = "$launchDir/postUpdateOutput"
      coreBestRepsFasta            = "$baseDir/peripheralOutput/coreBestReps.fasta"
      existingResidualBestRepsFasta = "$baseDir/postResidualOutput/bestReps.fasta"
      newResidualBestRepsFasta     = "$launchDir/updateResidualOutput/bestReps.fasta"
      coreAndPeripheralProteome    = "$launchDir/updatePeripheralOutput/fullProteome.fasta"
      updatedGroupsFile            = "$launchDir/updatePeripheralOutput/GroupsFile.txt"
      updatedResidualGroupsFile    = "$launchDir/updateResidualOutput/updatedResidualGroups.txt"
      existingResidualFasta        = "$baseDir/residualOutput/residualFasta.fa"
      newResidualFasta             = "$launchDir/updateResidualOutput/residualFasta.fa"
      oldGroupsFile                = "$baseDir/data/previousGroups/groups_OrthoMCL-CURRENT.txt"
      buildVersion                 = "7"
      bestRepDiamondOutputFields   = "qseqid sseqid evalue"
      updatedGroupFastas           = "$launchDir/updatePeripheralOutput/groupFastas"
      existingResidualGroupFastas  = "$baseDir/postResidualOutput/residualGroupFastas"
      newResidualGroupFastas       = "$launchDir/updateResidualOutput/residualGroupFastas"
    }
    docker {
      enabled = true
    }
    singularity {
      enabled = false
    }
  }
}
